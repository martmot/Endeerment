# Supabase auth
# Project URL format: https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=
# Use your Supabase publishable / anon key here
VITE_SUPABASE_ANON_KEY=
# Public site URL used for OAuth redirects in production
VITE_APP_URL=

# Groq (used server-side only by the dev middleware in vite.config.ts)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
